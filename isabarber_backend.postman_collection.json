    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (CLIENT) - POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Client Demo\",\n  \"email\": \"client_demo@salon.test\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", function () { pm.response.to.have.status(201); });",
                  "try {",
                  "  const data = pm.response.json();",
                  "  if (data.token) pm.environment.set(\"token\", data.token);",
                  "  if (data.user) {",
                  "    pm.environment.set(\"userId\", data.user.id);",
                  "    pm.environment.set(\"role\", data.user.role);",
                  "    pm.environment.set(\"email\", data.user.email);",
                  "  }",
                  "} catch(e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (utiliser variables env) - POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.environment.set(\"token\", data.token);",
                  "pm.environment.set(\"userId\", data.user.id);",
                  "pm.environment.set(\"role\", data.user.role);",
                  "pm.environment.set(\"email\", data.user.email);"
                ]
              }
            }
          ]
        },
