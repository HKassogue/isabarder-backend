        {
          "name": "Logout (clear token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.unset('token');",
                  "pm.environment.unset('userId');",
                  "pm.environment.unset('role');",
                  "pm.environment.unset('email');",
                  "pm.test('Token cleared', function () { pm.expect(pm.environment.get('token')).to.eql(undefined); });"
                ]
              }
            }
          ],
